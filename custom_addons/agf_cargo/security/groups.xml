<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="group_agf_admin" model="res.groups">
            <field name="name">Admin AGF</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">Akses penuh ke semua data AGF Cargo.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_agf_manajer" model="res.groups">
            <field name="name">Manajer Operasional</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">Akses baca dan ubah pesanan dan batch; tidak bisa hapus.</field>
        </record>

        <record id="group_agf_gudang" model="res.groups">
            <field name="name">Petugas Gudang</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">Akses baca pesanan dan update tahapan (status + foto).</field>
        </record>

    </data>
</odoo>
