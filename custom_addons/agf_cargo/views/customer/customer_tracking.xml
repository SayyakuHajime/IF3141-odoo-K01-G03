<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="customer_tracking" name="AGF Cargo — Tracking Pengiriman">
<t t-call="website.layout">
    <t t-set="no_header" t-value="1"/>
    <t t-set="no_footer" t-value="1"/>
    <t t-set="editable" t-value="0"/>

    <div class="agf-portal">

        <!-- TOP NAV TABS -->
        <div class="agf-portal__tabs">
            <a href="/agf/customer/tracking"
                class="agf-portal__tab agf-portal__tab--active">
                Tracking Pengiriman
            </a>
            <a href="/agf/customer/daftar"
                class="agf-portal__tab">
                Pendaftaran Kargo
            </a>
        </div>

        <!-- HEADER -->
        <div class="agf-portal__header">
            <h2 class="agf-portal__title">Selamat datang kembali!</h2>
            <p class="agf-portal__subtitle">
                Masukkan nomor registrasi pengiriman anda untuk melihat
                progress pengiriman tanaman hias anda
            </p>
        </div>

        <!-- SEARCH FORM -->
        <form action="/agf/customer/tracking" method="GET"
                class="agf-tracking__form">
            <input
                type="text"
                name="nomor"
                class="agf-tracking__input"
                placeholder="Masukkan Nomor Registrasi Anda ..."
                t-att-value="nomor or ''"
                autocomplete="off"
            />
        </form>

        <!-- ERROR -->
        <t t-if="error">
            <div class="agf-tracking__error">
                <i data-lucide="alert-circle"
                    style="width:16px;height:16px"/>
                <span t-esc="error"/>
            </div>
        </t>

        <!-- HASIL TRACKING -->
        <t t-if="kargo">

            <t t-set="is_penitip"
                t-value="nomor and nomor.upper().startswith('AGF-')"/>

            <div class="agf-tracking__result">

                <!-- BADGE NOMOR + WA BUTTON -->
                <div class="agf-tracking__badge-row">
                    <span class="agf-tracking__badge">
                        <t t-esc="nomor"/>
                    </span>
                    <span class="agf-tracking__badge
                                agf-tracking__badge--ups">
                        UPS Tracking
                    </span>
                    <t t-if="is_penitip">
                        <a href="https://wa.me/6281234567890"
                            target="_blank"
                            class="agf-tracking__wa-btn">
                            <i data-lucide="message-circle"
                                style="width:14px;height:14px"/>
                            Hubungi Admin
                        </a>
                    </t>
                </div>

                <!-- TIMELINE -->
                <div class="agf-tracking__timeline">

                    <t t-set="all_steps" t-value="[
                        ('01_registrasi',    'Pendaftaran Kargo'),
                        ('02_penjemputan',   'Penjemputan'),
                        ('03_gudang_asal',   'Penerimaan di Gudang Asal'),
                        ('04_cek_dokumen',   'Pemeriksaan Dokumen'),
                        ('05_terminal_asal', 'Terminal Kargo Asal'),
                        ('06_transit',       'Dalam Perjalanan'),
                        ('07_terminal_tujuan','Terminal Kargo Tujuan'),
                        ('08_bea_cukai',     'Pemeriksaan Bea Cukai'),
                        ('09_gudang_tujuan', 'Gudang Tujuan'),
                        ('10_pengiriman',    'Dalam Pengiriman'),
                        ('11_tiba',          'Tiba di Alamat'),
                        ('12_selesai',       'Selesai'),
                    ]"/>

                    <t t-foreach="all_steps" t-as="step">
                        <t t-set="step_key"   t-value="step[0]"/>
                        <t t-set="step_label" t-value="step[1]"/>

                        <t t-set="log" t-value="
                            kargo.tahapan_ids.filtered(
                                lambda t: t.tahap == step_key
                            )[:1]
                        "/>
                        <t t-set="is_done"   t-value="bool(log)"/>
                        <t t-set="is_active" t-value="
                            log and log == kargo.tahapan_ids[:1]
                        "/>

                        <div t-attf-class="agf-timeline__item
                            {{ 'agf-timeline__item--done' if is_done else '' }}
                            {{ 'agf-timeline__item--active' if is_active else '' }}
                            {{ 'agf-timeline__item--pending' if not is_done else '' }}">

                            <!-- DOT -->
                            <div class="agf-timeline__dot"/>

                            <!-- CONTENT -->
                            <div class="agf-timeline__content">

                                <p class="agf-timeline__step-name">
                                    <t t-esc="step_label"/>
                                </p>

                                <t t-if="log">

                                    <!-- Lokasi + Waktu -->
                                    <p class="agf-timeline__meta">
                                        <t t-if="log.lokasi">
                                            <i data-lucide="map-pin"
                                                style="width:11px;height:11px"/>
                                            <span t-esc="log.lokasi"/>
                                            ·
                                        </t>
                                        <i data-lucide="clock"
                                            style="width:11px;height:11px"/>
                                        <span t-esc="log.timestamp"
                                                t-options='{
                                                    "widget":"datetime",
                                                    "format":"dd MMM, HH:mm"
                                                }'/>
                                    </p>

                                    <!-- Foto kondisi -->
                                    <t t-if="log.foto_ids">
                                        <div class="agf-timeline__photos">
                                            <t t-foreach="log.foto_ids"
                                                t-as="foto">
                                                <img
                                                    t-attf-src="/web/image/ir.attachment/#{foto.id}/datas"
                                                    class="agf-timeline__photo"
                                                    alt="Foto kondisi"
                                                />
                                            </t>
                                        </div>
                                    </t>

                                    <!-- Status tanaman -->
                                    <t t-set="kondisi_list"
                                        t-value="kargo.tanaman_ids.mapped('kondisi')"/>
                                    <t t-if="kondisi_list">
                                        <t t-set="kondisi_label"
                                            t-value="
                                                'Bermasalah' if 'bermasalah' in kondisi_list
                                                else 'Kurang Sehat' if 'kurang_sehat' in kondisi_list
                                                else 'Healthy'
                                            "/>
                                        <span t-attf-class="agf-timeline__status-badge
                                            agf-timeline__status-badge--{{
                                                'red' if kondisi_label == 'Bermasalah'
                                                else 'yellow' if kondisi_label == 'Kurang Sehat'
                                                else 'green'
                                            }}">
                                            <t t-esc="kondisi_label"/>
                                        </span>
                                    </t>

                                    <!-- Catatan -->
                                    <t t-if="log.catatan">
                                        <p class="agf-timeline__note">
                                            "<t t-esc="log.catatan"/>"
                                        </p>
                                    </t>

                                    <!-- AKSI KHUSUS PENITIP -->
                                    <t t-if="is_penitip">

                                        <!-- Upload bukti pembayaran -->
                                        <t t-if="step_key == '01_registrasi' and not kargo.bukti_pembayaran">
                                            <div class="agf-timeline__action">
                                                <p class="agf-timeline__action-label">
                                                    Lakukan pembayaran
                                                </p>
                                                <form
                                                    t-attf-action="/agf/customer/upload_bukti/#{kargo.id}"
                                                    method="POST"
                                                    enctype="multipart/form-data">
                                                    <input type="hidden"
                                                            name="csrf_token"
                                                            t-att-value="request.csrf_token()"/>
                                                    <input type="hidden"
                                                            name="nomor"
                                                            t-att-value="nomor"/>
                                                    <input
                                                        type="file"
                                                        name="bukti_file"
                                                        accept="image/*,application/pdf"
                                                        class="agf-timeline__file-input"
                                                        id="bukti_file"
                                                    />
                                                    <label for="bukti_file"
                                                            class="agf-timeline__upload-btn">
                                                        <i data-lucide="upload"
                                                            style="width:14px;height:14px"/>
                                                        Upload Bukti Pembayaran
                                                    </label>
                                                    <button type="submit"
                                                            id="submit_bukti"
                                                            style="display:none">
                                                        Kirim
                                                    </button>
                                                </form>
                                                <script>
                                                    document.getElementById('bukti_file')
                                                        .addEventListener('change', function() {
                                                            document.getElementById('submit_bukti').click();
                                                        });
                                                </script>
                                            </div>
                                        </t>

                                        <!-- Bukti sudah diupload -->
                                        <t t-if="step_key == '01_registrasi' and kargo.bukti_pembayaran">
                                            <div class="agf-timeline__action
                                                        agf-timeline__action--done">
                                                <i data-lucide="check-circle"
                                                    style="width:14px;height:14px"/>
                                                Bukti pembayaran telah dikirim
                                            </div>
                                        </t>

                                        <!-- Konfirmasi tanaman diambil -->
                                        <t t-if="step_key == '02_penjemputan' and is_active and not kargo.konfirmasi_penjemputan">
                                            <form
                                                t-attf-action="/agf/customer/konfirmasi_jemput/#{kargo.id}"
                                                method="POST">
                                                <input type="hidden"
                                                        name="csrf_token"
                                                        t-att-value="request.csrf_token()"/>
                                                <input type="hidden"
                                                        name="nomor"
                                                        t-att-value="nomor"/>
                                                <button type="submit"
                                                        class="agf-timeline__confirm-btn">
                                                    <i data-lucide="check"
                                                        style="width:14px;height:14px"/>
                                                    Konfirmasi Tanaman Telah Diambil
                                                </button>
                                            </form>
                                        </t>

                                        <!-- Konfirmasi sudah dilakukan -->
                                        <t t-if="step_key == '02_penjemputan' and kargo.konfirmasi_penjemputan">
                                            <div class="agf-timeline__action
                                                        agf-timeline__action--done">
                                                <i data-lucide="check-circle"
                                                    style="width:14px;height:14px"/>
                                                Tanaman telah dikonfirmasi diambil
                                            </div>
                                        </t>

                                    </t>
                                    <!-- END aksi penitip -->

                                </t>
                                <!-- END t-if log -->

                            </div>
                        </div>

                    </t>
                    <!-- END t-foreach -->

                </div>
                <!-- END timeline -->

            </div>

        </t>
        <!-- END t-if kargo -->

    </div>

    <script src="https://cdn.jsdelivr.net/npm/lucide@0.462.0/dist/umd/lucide.min.js"/>
    <script>lucide.createIcons();</script>

</t>
</template>
</odoo>